{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "personalityquizzes",
  "compatibility_date": "2026-02-24",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "custom_domains": [
    { "hostname": "mypersonalityquizzes.com", "override_existing_dns_record": true },
    { "hostname": "www.mypersonalityquizzes.com", "override_existing_dns_record": true }
  ]
}
