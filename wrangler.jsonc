{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "personalityquizzes",
  "compatibility_date": "2026-02-24",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "custom_domains": [
    "mypersonalityquizzes.com",
    "www.mypersonalityquizzes.com"
  ]
}
